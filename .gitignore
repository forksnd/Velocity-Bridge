# ==========================================
#  VELOCITY BRIDGE - GLOBAL GITIGNORE
# ==========================================

# ------------------------------------------
#  1. SECURITY & PRIVATE MATERIAL
# ------------------------------------------
# Private signing keys (NEVER COMMIT)
.gitignore
src-tauri/velocity.key
*.key
*.pem
.env
.env.*
! .env.example
*_rsa
*_dsa
*.ppk

# ------------------------------------------
#  2. AI & AUTO-GENERATED ARTIFACTS
# ------------------------------------------
.gemini/
.cursor/
.claude/
.chatgpt/
.openai/
.copilot/
_ai_context/
*.ai
*.bkp
*.tmp
*.bak
*.temp


# ------------------------------------------
#  3. TEST & DEV CONFIGURATION (LOCAL ONLY)
# ------------------------------------------
# User requested these be kept local
src-python/pytest.ini
src-python/tests/
src/__tests__/
vitest.config.ts

# ------------------------------------------
#  4. PYTHON (BACKEND)
# ------------------------------------------
__pycache__/
*.py[cod]
*$py.class
# C extensions
*.so
# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
# Virtual Environments
venv/
.venv/
env/
.env/
src-python/venv/
src-python/build/
src-python/dist/
src-python/*.spec
# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/

# ------------------------------------------
#  5. NODE.JS / JAVASCRIPT (FRONTEND)
# ------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm/
.yarn/
coverage/
.nyc_output/
.pnp.*

# ------------------------------------------
#  6. TAURI / RUST
# ------------------------------------------
src-tauri/target/
src-tauri/gen/
**/.DS_Store
Thumb.db

# ------------------------------------------
