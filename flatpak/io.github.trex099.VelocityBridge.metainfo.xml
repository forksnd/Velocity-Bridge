<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.trex099.VelocityBridge</id>
  <name>Velocity Bridge</name>
  <summary>iOS to Linux Clipboard Sync</summary>
  
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-only</project_license>
  
  <developer id="io.github.trex099">
    <name>Trex099</name>
  </developer>
  
  <description>
    <p>
      Copy on iPhone. Paste on Linux. That's it.
    </p>
    <p>
      Velocity Bridge syncs your iPhone clipboard to your Linux desktop over your local network.
      No cloud, no subscription, just copy and paste.
    </p>
    <p>Features:</p>
    <ul>
      <li>Text clipboard sync</li>
      <li>Image clipboard sync (HEIC to PNG conversion)</li>
      <li>URL auto-open in browser</li>
      <li>Desktop notifications with sound</li>
      <li>System tray integration</li>
      <li>Clipboard history with search</li>
      <li>QR codes for easy iOS Shortcuts setup</li>
      <li>Start at login option</li>
      <li>Automatic update notifications</li>
    </ul>
  </description>
  
  <url type="homepage">https://github.com/Trex099/Velocity-Bridge</url>
  <url type="bugtracker">https://github.com/Trex099/Velocity-Bridge/issues</url>
  
  <launchable type="desktop-id">io.github.trex099.VelocityBridge.desktop</launchable>
  
  <screenshots>
    <screenshot type="default">
      <caption>Dashboard showing server status and connection info</caption>
      <image>https://raw.githubusercontent.com/Trex099/Velocity-Bridge/main/assets/screenshot-dashboard.png</image>
    </screenshot>
  </screenshots>
  
  <content_rating type="oars-1.1" />
  
  <releases>
    <release version="3.0.0" date="2025-01-20">
      <description>
        <p>Major Update - Tauri v2 Upgrade</p>
        <ul>
          <li>Upgraded to Tauri v2 for improved performance</li>
          <li>Enhanced system tray integration</li>
          <li>iOS Setup guide with QR codes</li>
          <li>Improved clipboard sync reliability</li>
        </ul>
      </description>
    </release>
    <release version="2.0.4" date="2024-12-10">
      <description>
        <p>Smart Update Release</p>
        <ul>
          <li>Headless mode support (systemd service)</li>
          <li>Smart update notifications based on install method</li>
          <li>Security token auto-generation fix</li>
          <li>Show/Hide toggle for token and IP</li>
        </ul>
      </description>
    </release>
    <release version="2.0.0" date="2024-12-08">
      <description>
        <p>Complete Rewrite with Tauri</p>
        <ul>
          <li>New Tauri + React GUI (faster, native look)</li>
          <li>System tray - close window, app keeps running</li>
          <li>Clipboard history with search</li>
          <li>Clear all history with one click</li>
          <li>Start at login toggle</li>
          <li>Automatic update checker</li>
        </ul>
      </description>
    </release>
    <release version="1.0.2" date="2024-12-07">
      <description>
        <p>Legacy Python/Tkinter version (deprecated)</p>
      </description>
    </release>
  </releases>
  
  <categories>
    <category>Utility</category>
    <category>Network</category>
  </categories>
  
  <keywords>
    <keyword>clipboard</keyword>
    <keyword>sync</keyword>
    <keyword>ios</keyword>
    <keyword>iphone</keyword>
    <keyword>paste</keyword>
    <keyword>copy</keyword>
    <keyword>tauri</keyword>
  </keywords>
  
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  
  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>
</component>
