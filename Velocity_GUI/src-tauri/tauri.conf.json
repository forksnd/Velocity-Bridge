{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Velocity-Bridge",
  "version": "3.0.3",
  "identifier": "com.arsh.velocity-bridge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Velocity Bridge",
        "width": 1000,
        "height": 750,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "velocity-backend"
    ],
    "createUpdaterArtifacts": false,
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1 | libappindicator3-1"
        ]
      }
    },
    "windows": {
      "wix": {
        "fragmentPaths": [
          "./wix/firewall.wxs"
        ],
        "componentRefs": [
          "FirewallExceptionCmp"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "RWQRWkJmclhOS3hQL3Z6NlIxY2pPbUVaUmc4YkFnS1RYS2pOVWJKU3RZeXp1WUhyei93cUpKODk=",
      "endpoints": [
        "https://github.com/Trex099/Velocity-Bridge/releases/latest/download/latest.json"
      ]
    },
    "autostart": null
  }
}
