---
/**
 * Icon.astro
 * Custom SVG icon system with inline rendering for performance.
 * Each icon is hand-drawn style, not generic.
 */

interface Props {
  name: 'lock' | 'bolt' | 'history' | 'sync' | 'github' | 'copy' | 'check' | 'arch' | 'fedora' | 'debian' | 'nix' | 'arrow-right' | 'menu' | 'close';
  size?: number;
  class?: string;
}

const { name, size = 24, class: className = '' } = Astro.props;

// SVG definitions for each icon
const icons: Record<string, string> = {
  // Lock - Security/Local network
  lock: `<path d="M12 2C9.24 2 7 4.24 7 7v3H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8a2 2 0 0 0-2-2h-1V7c0-2.76-2.24-5-5-5zm0 2c1.66 0 3 1.34 3 3v3H9V7c0-1.66 1.34-3 3-3zm0 10a2 2 0 1 1 0 4 2 2 0 0 1 0-4z" fill="currentColor"/>`,
  
  // Bolt - Speed/Performance
  bolt: `<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  
  // History - Clipboard history
  history: `<path d="M12 8v4l3 3m6-3a9 9 0 1 1-9-9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
           <path d="M12 3v3h3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  
  // Sync - Bidirectional
  sync: `<path d="M4 12a8 8 0 0 1 14.31-4.86M20 12a8 8 0 0 1-14.31 4.86" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
         <path d="M20 4v4h-4M4 20v-4h4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  
  // GitHub
  github: `<path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.604-3.369-1.341-3.369-1.341-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z" fill="currentColor"/>`,
  
  // Copy - Clipboard copy
  copy: `<rect x="9" y="9" width="13" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="2"/>
         <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" fill="none" stroke="currentColor" stroke-width="2"/>`,
  
  // Check - Success/Copied
  check: `<path d="M20 6L9 17l-5-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  
  // Arch Linux
  arch: `<path d="M12 2C8.5 9 7 12 4 20c2-1 4-2 8-2s6 1 8 2c-3-8-4.5-11-8-18z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>`,
  
  // Fedora
  fedora: `<circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.5"/>
           <path d="M12 7v5h4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
           <path d="M7 12a5 5 0 0 1 5-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  
  // Debian
  debian: `<path d="M12 3c-5 0-9 4-9 9s4 9 9 9 9-4 9-9-4-9-9-9z" fill="none" stroke="currentColor" stroke-width="1.5"/>
           <path d="M12 7c2.5 0 4.5 2 4.5 4.5S14.5 16 12 16c-1 0-2-.3-2.8-.9" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  
  // Nix
  nix: `<path d="M12 2l-3 5h6l-3-5zm0 20l3-5H9l3 5zM2 12l3 5 3-5-3-5-3 5zm20 0l-3-5-3 5 3 5 3-5z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>`,
  
  // Arrow Right
  'arrow-right': `<path d="M5 12h14M12 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  
  // Menu (hamburger)
  menu: `<path d="M4 6h16M4 12h16M4 18h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>`,
  
  // Close (X)
  close: `<path d="M18 6L6 18M6 6l12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>`
};

const svgContent = icons[name] || '';
---

<svg 
  xmlns="http://www.w3.org/2000/svg" 
  width={size} 
  height={size} 
  viewBox="0 0 24 24" 
  class:list={['icon', `icon-${name}`, className]}
  aria-hidden="true"
  set:html={svgContent}
/>

<style>
  .icon {
    display: inline-block;
    flex-shrink: 0;
    vertical-align: middle;
  }
</style>
