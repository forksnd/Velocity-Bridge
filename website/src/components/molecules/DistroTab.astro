---
/**
 * DistroTab.astro
 * Tab button for distribution selection in the install section.
 */

import Icon from '../atoms/Icon.astro';

interface Props {
  distro: 'arch' | 'fedora' | 'debian' | 'nix';
  label: string;
  panelId: string;
  selected?: boolean;
}

const { distro, label, panelId, selected = false } = Astro.props;
const tabId = `tab-${distro}`;
---

<button 
  role="tab"
  id={tabId}
  aria-controls={panelId}
  aria-selected={selected}
  class:list={['distro-tab', selected && 'distro-tab--active']}
  tabindex={selected ? 0 : -1}
>
  <Icon name={distro} size={20} />
  <span class="distro-tab__label">{label}</span>
</button>

<style lang="scss">
  @use '../../styles/_variables' as *;
  
  .distro-tab {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 0.75rem;
    background: transparent;
    border: $border-width solid $border-color;
    border-radius: $border-radius-md;
    color: $color-text-secondary;
    font-family: $font-body;
    font-size: 0.8125rem;
    font-weight: $font-weight-medium;
    cursor: pointer;
    transition: all $transition-base $ease-out;
    
    @media (min-width: 640px) {
      gap: $space-2;
      padding: $space-3 $space-4;
      font-size: $font-size-small;
    }
    
    &:hover:not(.distro-tab--active) {
      border-color: rgba($color-primary, 0.5);
      color: $color-primary;
    }
    
    &:focus-visible {
      outline: 2px solid $color-primary;
      outline-offset: 2px;
    }
    
    &--active {
      background: $color-primary;
      border-color: $color-primary;
      color: #000000;
      
      :global(.icon) {
        color: #000000;
      }
    }
    
    :global(.icon) {
      color: $color-muted;
      transition: color $transition-base $ease-out;
    }
    
    &:hover:not(.distro-tab--active) :global(.icon) {
      color: $color-primary;
    }
    
    &__label {
      @media (max-width: 400px) {
        // Very small screens: hide label, show only icon
        display: none;
      }
    }
  }
</style>
